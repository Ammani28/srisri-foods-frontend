re.gravatar.com/avatar/04f44b0019268df7093609e1422a62e6277c1130d24abf1e6aac5f8a6eba5a63?s=96&amp;d=mm&amp;r=g","url":"https://secure.gravatar.com/avatar/04f44b0019268df7093609e1422a62e6277c1130d24abf1e6aac5f8a6eba5a63?s=96&amp;d=mm&amp;r=g","caption":"admin","inLanguage":"en-US"},"sameAs":["https://natashamohan.com"],"worksFor":{"@id":"https://www.natashamohan.com/#organization"}},{"@type":"Recipe","name":"Dry Fruit Smoothie Recipe \u2013 Healthy, Nutritious, and Easy to Make","datePublished":"2025-02-26T10:11:22+05:30","author":{"@id":"https://www.natashamohan.com/author/admin/","name":"admin"},"description":"A delicious and nutritious dry fruit smoothie packed with almonds, cashews, walnuts, and dates. Perfect for breakfast, post-workout, or as an energy booster.","prepTime":"4 hours for soaking dry fruits","cookTime":"5 minutes for blending","totalTime":"PT4H5M (Total preparation and blending time","recipeCategory":"Smoothie, Healthy Drink","recipeCuisine":"Indian","keywords":"Dry fruit smoothie, healthy smoothie, energy drink, breakfast smoothie, post-workout drink","recipeYield":"2 servings","nutrition":{"@type":"NutritionInformation","calories":"Approximately 250 kcal per serving"},"recipeIngredient":[],"review":{"@type":"Review","datePublished":"2025-02-26T10:11:22+05:30","dateModified":"2025-02-26T10:39:48+05:30","author":{"@id":"https://www.natashamohan.com/author/admin/","name":"admin"},"reviewRating":{"@type":"Rating","ratingValue":"4.9","worstRating":"4.2","bestRating":"4.99"},"positiveNotes":{"@type":"ItemList","itemListElement":[{"@type":"ListItem","position":"1","name":"Nutrient-dense and energy-boosting"},{"@type":"ListItem","position":"2","name":"Naturally sweetened without refined sugar"},{"@type":"ListItem","position":"3","name":"Supports digestion and gut health"}]},"negativeNotes":{"@type":"ItemList","itemListElement":[{"@type":"ListItem","position":"1","name":"Requires soaking time for dry fruits"},{"@type":"ListItem","position":"2","name":"Might be high in calories if consumed in excess"}]}},"image":{"@id":"https://www.natashamohan.com/wp-content/uploads/2025/02/Dry-Fruit-Smoothie.jpg"},"recipeInstructions":"Soak almonds, cashews, and walnuts for at least 4 hours. Remove seeds from dates and chop them into small pieces. Rinse the raisins and figs. Add all soaked dry fruits into a blender. Pour in milk (or dairy-free alternative). Blend until smooth and creamy. Adjust consistency with more milk if needed. Add honey or banana for extra sweetness if required. Pour into a glass, garnish with chopped nuts or cinnamon. Serve chilled and enjoy!","@id":"https://www.natashamohan.com/dry-fruit-smoothie-recipe/#schema-127230","isPartOf":{"@id":"https://www.natashamohan.com/dry-fruit-smoothie-recipe/#webpage"},"publisher":{"@id":"https://www.natashamohan.com/#organization"},"inLanguage":"en-US"},{"@type":"VideoObject","name":"45 CALS TIKKI FOR WEIGHT LOSS #weighlosstips #recipe #food #weightlossdiet #diet #easy #tasty #new","description":"Boost your health with this delicious dry fruit smoothie recipe. Packed with nutrients, it&#039;s the perfect energy drink for all.","uploadDate":"2025-02-20T03:56:37-08:00","thumbnailUrl":"https://www.natashamohan.com/wp-content/uploads/2025/02/Dry-Fruit-Smoothie.jpg","embedUrl":"https://www.youtube.com/embed/-1WwpWBTj5I","duration":"PT0M43S","width":"1280","height":"720","isFamilyFriendly":"True","@id":"https://www.natashamohan.com/dry-fruit-smoothie-recipe/#schema-127232","isPartOf":{"@id":"https://www.natashamohan.com/dry-fruit-smoothie-recipe/#webpage"},"publisher":{"@id":"https://www.natashamohan.com/#organization"},"inLanguage":"en-US"}]}</script>
